#!/usr/bin/env bash

personal=`find ~/personal -maxdepth 2 -mindepth 1 -type d`
dev=`find $HOME/dev -maxdepth 1 -mindepth 1 -type d`
notes=`find $HOME/neorg -maxdepth 1 -type d`
bib=$HOME/biblioteca
dotfiles=$HOME/dotfiles

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=`echo -e "$personal\n$notes\n$dev\n$bib\n$dotfiles" | fzf --tmux=bottom`
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=`basename $selected | tr . _`

tmux new-session -A -s $selected_name -d -c $selected

if [[ -z $TMUX ]]; then
    tmux attach -t $selected_name
else
    tmux switch-client -t $selected_name
fi
